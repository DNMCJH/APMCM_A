  "power_calculation_formulas": {
    "description": "Mathematical models for energy consumption analysis",
    
    "instantaneous_power_W": {
      "total": "P_total = P_mechanical + P_copper + P_friction",
      "mechanical": "P_mechanical = (τ_joint × ω_joint) / η_mechanical",
      "copper_loss": "P_copper = I_motor² × R_motor",
      "friction_loss": "P_friction = τ_friction × |ω_joint|",
      "note": "All power components are always positive (dissipative)"
    },
    
    "motor_current_A": {
      "formula": "I_motor = τ_joint / Kt_effective",
      "note": "Assumes ideal torque-current relationship; neglects back-EMF limit"
    },
    
    "friction_torque_Nm": {
      "formula": "τ_friction = τ_coulomb × sign(ω_joint) + B_viscous × ω_joint",
      "coulomb_note": "Coulomb friction dominates at low speeds (Problem 1 static holding, Problem 3 slow movements)",
      "viscous_note": "Viscous friction dominates at high speeds (Problem 2 walking dynamics)"
    },
    
    "total_energy_J": {
      "formula": "E_total = ∫₀ᵀ P_total(t) dt",
      "numerical_integration": "Use trapezoidal rule or Simpson's rule for discrete trajectory data",
      "battery_check": "Verify E_total_Wh = E_total_J / 3600 ≤ battery usable_energy_Wh"
    }
  },
  
  "modeling_notes": {
    "assumption_1": "Motor operates in torque-control mode; voltage and back-EMF limits are not considered",
    "assumption_2": "Gearbox efficiency is constant; actual efficiency varies with load and speed",
    "assumption_3": "Thermal transients are neglected; steady-state thermal model is used",
    "assumption_4": "Iron losses (eddy current, hysteresis) are lumped into overall efficiency factor",
    "validation_note": "Parameter values are estimates; sensitivity analysis is recommended in optimization phase"
  }
